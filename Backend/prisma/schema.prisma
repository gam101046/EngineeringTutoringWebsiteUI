generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  engineType      = "library"
}

generator prismabox {
  provider                    = "prismabox"
  output                      = "../generated/prismabox"
  inputModel                  = "true"
  typeboxImportDependencyName = "elysia"
  typeboxImportVariableName   = "t"
}

datasource db {
  provider = "postgresql"
}

model Example {
  id     String   @id @default(cuid())
  name   String   @unique
  detail String
  price  Decimal?
}
